generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  ANALYST
  AUDITOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  COMPLIANCE_REVIEW
  FROZEN
}

enum WalletStatus {
  ACTIVE
  FROZEN
}

enum KycStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum RiskTier {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  USER_REGISTERED
  KYC_APPROVED
  KYC_REJECTED
  MONEY_SENT
  MONEY_RECEIVED
  WALLET_FROZEN
  WALLET_UNFROZEN
  LIMIT_WARNING
}

enum ActivityType {
  USER_REGISTERED
  USER_LOGGED_IN
  BENEFICIARY_ADDED
  TRANSFER_CREATED
  TRANSFER_COMPLETED
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  WALLET_FROZEN
  WALLET_UNFROZEN
  ADMIN_ACTION
}

enum FraudRule {
  RULE_001
  RULE_002
  RULE_003
  RULE_004
  RULE_005
}

enum FraudAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudAlertStatus {
  OPEN
  INVESTIGATING
  DISMISSED
  ESCALATED
  RESOLVED
}

enum FraudCaseResolution {
  FALSE_POSITIVE
  ACCOUNT_FROZEN
  WALLET_FROZEN
  USER_WARNED
  MONITOR_ONLY
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password_hash String
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  risk_tier     RiskTier   @default(LOW)
  refresh_token String?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  wallet        Wallet?
  login_history LoginHistory[]

  owned_beneficiaries  Beneficiary[] @relation("OwnerBeneficiaries")
  target_beneficiaries Beneficiary[] @relation("TargetBeneficiaries")

  kyc_submission   KycSubmission?
  notifications    Notification[]
  admin_audit_logs AdminAuditLog[]
  user_activities  UserActivity[]

  fraud_alerts     FraudAlert[]
  assigned_cases   FraudCase[] @relation("AssignedFraudCases")

  @@map("users")
}

model Wallet {
  id            String       @id @default(uuid())
  user_id       String       @unique
  wallet_number String       @unique
  balance       Decimal      @default(0.00) @db.Decimal(12, 2)
  status        WalletStatus @default(ACTIVE)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  sent_transactions     Transaction[] @relation("SentTransactions")
  received_transactions Transaction[] @relation("ReceivedTransactions")

  ledger_account  LedgerAccount?
  deposit_intents DepositIntent[]

  @@map("wallets")
}

model LoginHistory {
  id         String   @id @default(uuid())
  user_id    String
  ip_address String?
  device     String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model Beneficiary {
  id                  String   @id @default(uuid())
  owner_user_id       String
  beneficiary_user_id String
  nickname            String?
  is_favorite         Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  owner       User @relation("OwnerBeneficiaries", fields: [owner_user_id], references: [id], onDelete: Cascade)
  beneficiary User @relation("TargetBeneficiaries", fields: [beneficiary_user_id], references: [id], onDelete: Cascade)

  @@unique([owner_user_id, beneficiary_user_id])
  @@map("beneficiaries")
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  BLOCKED
}

model Transaction {
  id                    String            @id @default(uuid())
  transaction_reference String            @unique
  sender_wallet_id      String?
  receiver_wallet_id    String
  amount                Decimal           @db.Decimal(12, 2)
  status                TransactionStatus @default(PENDING)
  description           String?
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  sender   Wallet? @relation("SentTransactions", fields: [sender_wallet_id], references: [id])
  receiver Wallet  @relation("ReceivedTransactions", fields: [receiver_wallet_id], references: [id])

  ledger_entries  LedgerEntry[]
  risk_assessment RiskAssessment?
  fraud_alerts    FraudAlert[]

  @@index([sender_wallet_id])
  @@index([created_at])
  @@map("transactions")
}

// ----------------------------------------------------
// PHASE 4: FRAUD DETECTION & RISK
// ----------------------------------------------------

model RiskAssessment {
  id             String   @id @default(uuid())
  transaction_id String   @unique
  risk_score     Int      @default(0)
  flagged_rules  String[]
  evaluated_at   DateTime @default(now())

  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@map("risk_assessments")
}

model FraudAlert {
  id             String             @id @default(uuid())
  user_id        String
  transaction_id String?            
  rule           FraudRule
  title          String
  description    String
  severity       FraudAlertSeverity
  status         FraudAlertStatus   @default(OPEN)
  detected_at    DateTime           @default(now())
  created_at     DateTime           @default(now())

  user        User         @relation(fields: [user_id], references: [id])
  transaction Transaction? @relation(fields: [transaction_id], references: [id])
  fraud_case  FraudCase?

  @@index([user_id])
  @@index([status])
  @@index([severity, status])
  @@map("fraud_alerts")
}

model FraudCase {
  id            String               @id @default(uuid())
  alert_id      String               @unique
  assigned_to   String?              
  notes         String?
  resolution    FraudCaseResolution? 
  resolved_at   DateTime?
  created_at    DateTime             @default(now())

  alert    FraudAlert @relation(fields: [alert_id], references: [id], onDelete: Cascade)
  assignee User?      @relation("AssignedFraudCases", fields: [assigned_to], references: [id])

  @@index([assigned_to])
  @@map("fraud_cases")
}

// ----------------------------------------------------
// PHASE 3: LEDGER ARCHITECTURE
// ----------------------------------------------------

model LedgerAccount {
  id           String   @id @default(uuid())
  wallet_id    String?  @unique
  account_code String   @unique // USR-WALLET-XXXXXXXX or SYS-RESERVE
  account_name String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  wallet         Wallet?       @relation(fields: [wallet_id], references: [id])
  ledger_entries LedgerEntry[]

  @@map("ledger_accounts")
}

enum LedgerBatchStatus {
  PENDING
  POSTED
  REVERSED
}

model LedgerBatch {
  id              String            @id @default(uuid())
  batch_reference String            @unique // LGR-XXXXXXXX
  status          LedgerBatchStatus @default(PENDING)
  posted_at       DateTime?
  reversed_at     DateTime?
  created_at      DateTime          @default(now())

  entries LedgerEntry[]

  @@map("ledger_batches")
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model LedgerEntry {
  id                String          @id @default(uuid())
  transaction_id    String
  ledger_batch_id   String
  ledger_account_id String
  entry_type        LedgerEntryType
  amount            Decimal         @db.Decimal(12, 2)
  description       String?
  created_at        DateTime        @default(now())

  transaction    Transaction   @relation(fields: [transaction_id], references: [id])
  batch          LedgerBatch   @relation(fields: [ledger_batch_id], references: [id])
  ledger_account LedgerAccount @relation(fields: [ledger_account_id], references: [id])

  @@index([transaction_id])
  @@index([ledger_batch_id])
  @@index([ledger_account_id])
  @@index([created_at])
  @@map("ledger_entries")
}

// ----------------------------------------------------
// PHASE 5: WALLET FUNDING & DEPOSIT ENGINE
// ----------------------------------------------------

enum DepositStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model DepositIntent {
  id                 String        @id @default(uuid())
  reference          String        @unique // Secure internal tracking ID
  wallet_id          String
  amount             Decimal       @db.Decimal(15, 2)
  currency           String        @default("INR")
  status             DepositStatus @default(PENDING)
  provider_reference String?       @unique // External ID supplied by mock gateway
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  settled_at         DateTime?

  wallet Wallet @relation(fields: [wallet_id], references: [id])

  @@index([wallet_id])
  @@index([status])
  @@index([wallet_id, status])
  @@map("deposit_intents")
}

// ----------------------------------------------------
// PHASE 6.1: ENTERPRISE OPERATIONS & COMPLIANCE
// ----------------------------------------------------

model KycSubmission {
  id               String    @id @default(uuid())
  user_id          String    @unique
  pan_number       String?
  aadhaar_last4    String?
  aadhaar_hash     String?
  document_url     String?
  status           KycStatus @default(PENDING)
  rejection_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("kyc_submissions")
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  message    String
  action_url String?
  metadata   Json?
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
  @@map("notifications")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  admin_id   String
  action     String
  target_id  String
  details    Json?
  created_at DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id])

  @@map("admin_audit_logs")
}

model UserActivity {
  id         String       @id @default(uuid())
  user_id    String
  type       ActivityType
  ip_address String?
  device     String?
  metadata   Json?
  created_at DateTime     @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
  @@map("user_activities")
}
